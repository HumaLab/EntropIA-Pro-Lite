{
  "productName": "EntropIA Pro",
  "version": "0.1.1",
  "identifier": "com.entropia.pro.desktop",
  "build": {
    "beforeDevCommand": "pnpm --filter @entropia-pro/desktop dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "EntropIA Pro",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost https://asset.localhost data: blob: https://tile.openstreetmap.org https://*.tile.openstreetmap.org",
        "media-src": "'self' asset: http://asset.localhost https://asset.localhost blob:",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost https://ipc.localhost asset: http://asset.localhost https://asset.localhost",
        "worker-src": "'self' blob:",
        "frame-src": "'none'",
        "object-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'self'"
      },
      "devCsp": {
        "default-src": "'self'",
        "script-src": "'self'",
        "style-src": "'self' 'unsafe-inline'",
        "img-src": "'self' asset: http://asset.localhost https://asset.localhost data: blob: https://tile.openstreetmap.org https://*.tile.openstreetmap.org",
        "media-src": "'self' asset: http://asset.localhost https://asset.localhost blob:",
        "font-src": "'self' data:",
        "connect-src": "'self' ipc: http://ipc.localhost https://ipc.localhost asset: http://asset.localhost https://asset.localhost ws://localhost:1420 http://localhost:1420",
        "worker-src": "'self' blob:",
        "frame-src": "'none'",
        "object-src": "'none'",
        "base-uri": "'self'",
        "form-action": "'self'"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "Desktop workspace for qualitative research: audio transcription, document OCR, text analysis and RAG chat over your collections, with local and remote AI models.",
    "longDescription": "EntropIA Pro is a desktop research workspace for document and audio collections. It transcribes audio, extracts text from documents via OCR, runs NLP analysis (entities, triples, embeddings) and offers a RAG chat over the resulting knowledge base. ML features run on local models (Python runtime, on-device OCR) as well as remote providers.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      },
      "wix": {
        "fragmentPaths": ["./windows/fragments/force-webview2-bootstrapper.wxs"],
        "componentRefs": [
          "ForceWebView2BootstrapperHook",
          "AppLocalConcrt140",
          "AppLocalMsvcp140",
          "AppLocalMsvcp1401",
          "AppLocalVcomp140",
          "AppLocalVcruntime140",
          "AppLocalVcruntime1401"
        ]
      },
      "nsis": {
        "installerHooks": "./windows/hooks.nsh"
      }
    },
    "resources": [
      "resources/*",
      "resources/models/ner/*",
      "resources/models/ocr/*",
      "resources/lib/*",
      "resources/lib/linux-x86_64/**/*",
      "resources/tools/uv/windows-x86_64/*",
      "resources/tools/uv/windows-aarch64/*",
      "resources/runtime-pack/windows-x86_64/**/*",
      "resources/runtime-pack/linux-x86_64/**/*",
      "target/release/vc-runtime/*",
      "scripts/paddle_vl.py",
      "scripts/spacy_ner.py",
      "scripts/transcribe.py"
    ]
  }
}
